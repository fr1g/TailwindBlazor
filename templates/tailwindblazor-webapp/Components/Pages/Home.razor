@page "/"

<PageTitle>Home</PageTitle>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-4">
        Hello, Tailwind + Blazor!
    </h1>
    <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">
        This app is powered by <strong>TailwindBlazor</strong> — zero-config Tailwind CSS v4 for Blazor.
    </p>
    <a href="https://github.com/luissena/TailwindBlazor" target="_blank" rel="noopener"
       class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium rounded-lg transition-colors bg-indigo-600 text-white hover:bg-indigo-500">
        Get Started
    </a>
</div>
